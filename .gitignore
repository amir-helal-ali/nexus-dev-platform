# ============================================================
# NEXUS DEV — .gitignore
# ============================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js
.next/
out/
build/
dist/

# Production
*.tsbuildinfo
next-env.d.ts

# Environment variables (تحتوي على أسرار)
.env
.env.local
.env.development.local
.env.production.local
.env.test.local

# Database (SQLite local)
*.db
*.db-journal
db/*.db
db/*.db-journal

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dev.log
server.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
*.lcov
.nyc_output

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OS
.DS_Store

# Agent Browser / Sandbox
screenshots/
.zscripts/

# Skills (ClawHub skills - not part of project source)
skills/

# Worklog (local only)
worklog.md

# Build artifacts
*.tar
*.zip

# Misc
.cache/
.turbo/
.vercel

# Mini-service build
mini-services/*/node_modules/
mini-services/*/dist/

# Prisma generated (keep schema, ignore generated client)
# Note: @prisma/client is generated to node_modules so it's already ignored
