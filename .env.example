# ============================================================
# NEXUS DEV — Environment Variables Example
# ============================================================
# انسخ هذا الملف إلى .env وعدّل القيم

# Database (SQLite)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# NextAuth
NEXTAUTH_SECRET=change-this-to-a-very-long-random-secret-in-production
NEXTAUTH_URL=http://localhost:3000

# Chat Service Port (WebSocket)
CHAT_SERVICE_PORT=3003

# PayMob (اختياري - للدفع الفعلي)
# PAYMOB_API_KEY=your-paymob-api-key
# PAYMOB_INTEGRATION_ID=your-integration-id

# Email Service (اختياري - لإرسال البريد)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
